function binarySearch(sortedArray, target, keyFn = (x) => x) {
  let lo = 0;
  let hi = sortedArray.length - 1;
  while (lo <= hi) {
    const mid = (lo + hi) >> 1;
    const midKey = keyFn(sortedArray[mid]);
    if (midKey === target) return mid;
    if (midKey < target) lo = mid + 1;
    else hi = mid - 1;
  }
  return -1;
}

module.exports = { binarySearch };

class TrieNode {
  constructor() {
    this.children = new Map();
    this.isEnd = false;
    this.refs = [];
  }
}

class Trie {
  constructor() {
    this.root = new TrieNode();
  }

  insert(word, refId) {
    let node = this.root;
    for (const ch of word.toLowerCase()) {
      if (!node.children.has(ch)) node.children.set(ch, new TrieNode());
      node = node.children.get(ch);
    }
    node.isEnd = true;
    if (refId !== undefined) node.refs.push(refId);
  }

  searchPrefix(prefix) {
    let node = this.root;
    for (const ch of prefix.toLowerCase()) {
      if (!node.children.has(ch)) return [];
      node = node.children.get(ch);
    }
    const results = [];
    this._collect(node, results);
    return results;
  }

  _collect(node, results) {
    if (node.isEnd) results.push(...node.refs);
    for (const child of node.children.values()) this._collect(child, results);
  }
}

module.exports = { Trie };

class ListNode {
  constructor(value) {
    this.value = value;
    this.next = null;
  }
}

class BookingHistoryList {
  constructor() {
    this.head = null;
    this.tail = null;
    this.length = 0;
  }

  append(booking) {
    const node = new ListNode(booking);
    if (!this.tail) {
      this.head = this.tail = node;
    } else {
      this.tail.next = node;
      this.tail = node;
    }
    this.length++;
    return this;
  }

  recent(n = 10) {
    const all = [];
    let node = this.head;
    while (node) {
      all.push(node.value);
      node = node.next;
    }
    return all.slice(-n).reverse();
  }

  toArray() {
    const out = [];
    let node = this.head;
    while (node) {
      out.push(node.value);
      node = node.next;
    }
    return out;
  }
}

module.exports = { BookingHistoryList };

class UndoStack {
  constructor(limit = 20) {
    this.items = [];
    this.limit = limit;
  }

  push(entry) {
    this.items.push(entry);
    if (this.items.length > this.limit) this.items.shift();
  }

  undoLast() {
    const entry = this.items.pop();
    if (entry && typeof entry.undo === 'function') entry.undo();
    return entry || null;
  }

  peek() {
    return this.items[this.items.length - 1] || null;
  }

  size() {
    return this.items.length;
  }
}

module.exports = { UndoStack };

