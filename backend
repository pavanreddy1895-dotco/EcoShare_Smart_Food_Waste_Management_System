class HashMapIndex {
  constructor() {
    this.map = new Map();
  }
  set(key, value) {
    this.map.set(key, value);
    return this;
  }
  get(key) {
    return this.map.get(key);
  }
  has(key) {
    return this.map.has(key);
  }
  delete(key) {
