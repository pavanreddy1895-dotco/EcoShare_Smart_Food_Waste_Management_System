  }
  values() {
    return Array.from(this.map.values());
  }
  size() {
    return this.map.size;
  }
}

module.exports = { HashMapIndex };

class PriorityQueue {
  constructor(compareFn) {
    this.heap = [];
    this.compare = compareFn || ((a, b) => a - b);
  }

  size() {
    return this.heap.length;
  }

  isEmpty() {
    return this.heap.length === 0;
  }

  peek() {
    return this.heap[0];
  }

  push(item) {
    this.heap.push(item);
    this._bubbleUp(this.heap.length - 1);
    return this;
  }

  pop() {
    if (this.heap.length === 0) return undefined;
    const top = this.heap[0];
    const last = this.heap.pop();
    if (this.heap.length > 0) {
      this.heap[0] = last;
      this._bubbleDown(0);
    }
    return top;
  }

  _bubbleUp(i) {
    while (i > 0) {
      const parent = Math.floor((i - 1) / 2);
      if (this.compare(this.heap[i], this.heap[parent]) < 0) {
        [this.heap[i], this.heap[parent]] = [this.heap[parent], this.heap[i]];
        i = parent;
      } else break;
    }
  }

  _bubbleDown(i) {
    const n = this.heap.length;
    while (true) {
      let smallest = i;
      const left = 2 * i + 1;
      const right = 2 * i + 2;
      if (left < n && this.compare(this.heap[left], this.heap[smallest]) < 0) smallest = left;
      if (right < n && this.compare(this.heap[right], this.heap[smallest]) < 0) smallest = right;
      if (smallest === i) break;
      [this.heap[i], this.heap[smallest]] = [this.heap[smallest], this.heap[i]];
      i = smallest;
    }
  }
}

function expiryQueue(leftovers) {
  const pq = new PriorityQueue((a, b) => new Date(a.expiry_at) - new Date(b.expiry_at));
  leftovers.forEach((item) => pq.push(item));
  return pq;
}

module.exports = { PriorityQueue, expiryQueue };

class Graph {
  constructor() {
    this.adjacency = new Map();
  }

  addNode(id) {
    if (!this.adjacency.has(id)) this.adjacency.set(id, []);
  }

  addEdge(fromId, toId, weight) {
    this.addNode(fromId);
    this.addNode(toId);
    this.adjacency.get(fromId).push({ to: toId, weight });
    this.adjacency.get(toId).push({ to: fromId, weight });
  }

  dijkstra(sourceId) {
    const distances = new Map();
    const previous = new Map();
    const visited = new Set();

    for (const node of this.adjacency.keys()) distances.set(node, Infinity);
    distances.set(sourceId, 0);

    while (visited.size < this.adjacency.size) {
      let current = null;
      let currentDist = Infinity;
      for (const [node, dist] of distances) {
        if (!visited.has(node) && dist < currentDist) {
          current = node;
          currentDist = dist;
        }
      }
      if (current === null) break;
      visited.add(current);

      for (const edge of this.adjacency.get(current) || []) {
        const candidate = currentDist + edge.weight;
        if (candidate < distances.get(edge.to)) {
          distances.set(edge.to, candidate);
          previous.set(edge.to, current);
        }
      }
    }

    return { distances, previous };
  }

  static buildPath(previous, sourceId, targetId) {
    const path = [targetId];
    let current = targetId;
    while (current !== sourceId) {
      current = previous.get(current);
      if (current === undefined) return null;
      path.unshift(current);
    }
    return path;
  }

  shortestPath(sourceId, targetId) {
    const { distances, previous } = this.dijkstra(sourceId);
    return {
      distance: distances.get(targetId) ?? Infinity,
      path: Graph.buildPath(previous, sourceId, targetId),
    };
  }
}

module.exports = { Graph };

function assignNearestNgo(leftover, ngosWithDistance, remainingCapacity) {
  const sorted = [...ngosWithDistance].sort((a, b) => a.distance_km - b.distance_km);

  for (const candidate of sorted) {
    const capacityLeft = remainingCapacity.get(candidate.ngo_id) ?? 0;
    if (capacityLeft >= leftover.quantity) {
      remainingCapacity.set(candidate.ngo_id, capacityLeft - leftover.quantity);
      return candidate;
    }
  }
  return null;
}

function priorityScore({ freshnessScore, distanceKm, quantityKg, maxQuantityKg = 50 }) {
  const freshnessTerm = 0.5 * freshnessScore;
  const distanceTerm = 0.3 * (100 / (1 + distanceKm));
  const quantityTerm = 0.2 * Math.min(100, (quantityKg / maxQuantityKg) * 100);
  return Math.round((freshnessTerm + distanceTerm + quantityTerm) * 100) / 100;
}

module.exports = { assignNearestNgo, priorityScore };

function sortByExpiry(items) {
