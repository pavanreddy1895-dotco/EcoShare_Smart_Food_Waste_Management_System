async function bookMeal(req, res) {
  const { menu_id, cutoff_at } = req.body;
  if (!menu_id) return res.status(400).json({ error: 'menu_id is required' });

  const [existing] = await pool.query(
    "SELECT id FROM bookings WHERE student_id = ? AND menu_id = ? AND status = 'booked'",
    [req.user.id, menu_id]
  );
  if (existing.length) return res.status(409).json({ error: 'Already booked for this meal' });

  const [result] = await pool.query(
    'INSERT INTO bookings (student_id, menu_id, status, booked_at, cutoff_at) VALUES (?, ?, "booked", NOW(), ?)',
    [req.user.id, menu_id, cutoff_at || null]
  );

  const qr = generateMealPassCode(result.insertId);
  await pool.query('UPDATE bookings SET qr_code = ? WHERE id = ?', [qr, result.insertId]);

  await pool.query(
    'INSERT INTO eco_point_ledger (user_id, points, reason, created_at) VALUES (?, 5, "meal_booked", NOW())',
    [req.user.id]
  );
  await pool.query('UPDATE users SET eco_points = eco_points + 5 WHERE id = ?', [req.user.id]);

  await notify(req.user, { channel: 'push', title: 'Meal booked', body: `Pass ${qr} generated.` });

  return res.status(201).json({ booking_id: result.insertId, qr_code: qr });
}

async function cancelBooking(req, res) {
  const { id } = req.params;
  const [rows] = await pool.query('SELECT * FROM bookings WHERE id = ? AND student_id = ?', [id, req.user.id]);
  const booking = rows[0];
  if (!booking) return res.status(404).json({ error: 'Booking not found' });
  if (booking.cutoff_at && new Date() > new Date(booking.cutoff_at)) {
    return res.status(400).json({ error: 'Cutoff has passed, cannot cancel' });
  }
  await pool.query('UPDATE bookings SET status = "cancelled" WHERE id = ?', [id]);
  return res.json({ ok: true });
}

