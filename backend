async function predictDemand(req, res) {
  const { kitchen_id, meal_type } = req.query;

  const [history] = await pool.query(
    `SELECT DATE(b.booked_at) AS d, COUNT(*) AS cnt
     FROM bookings b JOIN menus m ON m.id = b.menu_id
     WHERE m.kitchen_id = ? AND m.meal_type = ? AND b.status != 'cancelled'
       AND b.booked_at >= DATE_SUB(CURDATE(), INTERVAL 14 DAY)
     GROUP BY DATE(b.booked_at)`,
    [kitchen_id, meal_type]
  );

  if (history.length === 0) {
    return res.json({ predicted_qty: null, confidence: 0, note: 'Not enough history yet' });
  }

  const counts = history.map((r) => r.cnt);
  const avg = counts.reduce((a, b) => a + b, 0) / counts.length;
  const variance = counts.reduce((sum, c) => sum + (c - avg) ** 2, 0) / counts.length;
  const stdDev = Math.sqrt(variance);

  const today = new Date();
  const isWeekend = [0, 6].includes(today.getDay());
  const weekendAdjustment = isWeekend ? 0.9 : 1.0;

  const predicted = Math.round(avg * weekendAdjustment);
  const confidence = Math.max(50, Math.min(98, Math.round(100 - (stdDev / (avg || 1)) * 100)));

  await pool.query(
    `INSERT INTO demand_predictions (kitchen_id, meal_date, meal_type, predicted_qty, confidence, factors)
     VALUES (?, CURDATE(), ?, ?, ?, ?)`,
    [kitchen_id, meal_type, predicted, confidence, JSON.stringify({ avg, stdDev, isWeekend, sampleDays: counts.length })]
  );

  return res.json({ predicted_qty: predicted, confidence, sample_days: counts.length });
}

module.exports = { predictDemand };

