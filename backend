const { Graph } = require('../../dsa-engine/graph');
const { assignNearestNgo, priorityScore } = require('../../dsa-engine/greedyMatch');
const { expiryQueue } = require('../../dsa-engine/priorityQueue');

function haversineKm(lat1, lon1, lat2, lon2) {
  const R = 6371;
  const dLat = ((lat2 - lat1) * Math.PI) / 180;
  const dLon = ((lon2 - lon1) * Math.PI) / 180;
  const a =
    Math.sin(dLat / 2) ** 2 +
    Math.cos((lat1 * Math.PI) / 180) * Math.cos((lat2 * Math.PI) / 180) * Math.sin(dLon / 2) ** 2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
}

async function listAvailableForNgo(req, res) {
  const [leftovers] = await pool.query(`SELECT * FROM leftovers WHERE status = 'available'`);
  const [ngo] = await pool.query('SELECT * FROM ngos WHERE id = ?', [req.query.ngo_id]);
  const thisNgo = ngo[0];
  if (!thisNgo) return res.status(404).json({ error: 'NGO not found' });

  const [kitchens] = await pool.query('SELECT * FROM kitchens');
  const kitchenById = new Map(kitchens.map((k) => [k.id, k]));

  const ranked = leftovers
    .map((item) => {
      const kitchen = kitchenById.get(item.kitchen_id);
      const distanceKm = kitchen
        ? Math.round(haversineKm(kitchen.latitude, kitchen.longitude, thisNgo.latitude, thisNgo.longitude) * 10) / 10
        : null;
      return {
        ...item,
        distance_km: distanceKm,
        priority_score: priorityScore({
          freshnessScore: item.freshness_score,
          distanceKm: distanceKm ?? 999,
          quantityKg: item.quantity,
        }),
      };
    })
    .sort((a, b) => b.priority_score - a.priority_score);

  return res.json(ranked);
}

async function acceptDonation(req, res) {
  const { leftoverId } = req.params;
  const { ngo_id } = req.body;

  const [[leftover]] = await pool.query('SELECT * FROM leftovers WHERE id = ?', [leftoverId]);
  if (!leftover || leftover.status !== 'available') {
    return res.status(409).json({ error: 'Leftover not available' });
  }

  const [[kitchen]] = await pool.query('SELECT * FROM kitchens WHERE id = ?', [leftover.kitchen_id]);
  const [[ngo]] = await pool.query('SELECT * FROM ngos WHERE id = ?', [ngo_id]);

  const g = new Graph();
  const kNode = `kitchen_${kitchen.id}`;
  const nNode = `ngo_${ngo.id}`;
  g.addEdge(kNode, nNode, haversineKm(kitchen.latitude, kitchen.longitude, ngo.latitude, ngo.longitude));
  const { distance } = g.shortestPath(kNode, nNode);
  const etaMinutes = Math.round((distance / 25) * 60);

  const [result] = await pool.query(
    `INSERT INTO donations (leftover_id, ngo_id, kitchen_id, distance_km, eta_minutes, priority_score, status, matched_at)
     VALUES (?, ?, ?, ?, ?, ?, 'matched', NOW())`,
    [leftoverId, ngo_id, kitchen.id, distance, etaMinutes,
      priorityScore({ freshnessScore: leftover.freshness_score, distanceKm: distance, quantityKg: leftover.quantity })]
  );
  await pool.query(`UPDATE leftovers SET status = 'matched' WHERE id = ?`, [leftoverId]);

  return res.status(201).json({ donation_id: result.insertId, distance_km: distance, eta_minutes: etaMinutes });
}

async function expiryOrderedQueue(req, res) {
  const [rows] = await pool.query(
    `SELECT * FROM leftovers WHERE kitchen_id = ? AND status = 'available'`,
    [req.query.kitchen_id]
  );
  const pq = expiryQueue(rows);
  const ordered = [];
  while (!pq.isEmpty()) ordered.push(pq.pop());
  return res.json(ordered);
}

async function markDelivered(req, res) {
  const { id } = req.params;
  await pool.query(
    `UPDATE donations SET status = 'delivered', delivered_at = NOW(), certificate_url = ? WHERE id = ?`,
    [`/certificates/donation-${id}.pdf`, id]
  );
  return res.json({ ok: true });
}

module.exports = { listAvailableForNgo, acceptDonation, expiryOrderedQueue, markDelivered, haversineKm };

