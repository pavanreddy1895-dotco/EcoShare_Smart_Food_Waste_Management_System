function computeFreshnessScore(cookedAt, expiryAt, now = new Date()) {
  const cooked = new Date(cookedAt).getTime();
  const expiry = new Date(expiryAt).getTime();
  const current = now.getTime();
  if (current >= expiry) return 0;
  if (current <= cooked) return 100;
  return Math.round(((expiry - current) / (expiry - cooked)) * 10000) / 100;
}

async function logLeftover(req, res) {
  const { kitchen_id, food_name, quantity, unit, cooked_at, expiry_at } = req.body;
  const freshness_score = computeFreshnessScore(cooked_at, expiry_at);

  const [result] = await pool.query(
    `INSERT INTO leftovers (kitchen_id, food_name, quantity, unit, cooked_at, expiry_at, freshness_score, status)
     VALUES (?, ?, ?, ?, ?, ?, ?, 'available')`,
